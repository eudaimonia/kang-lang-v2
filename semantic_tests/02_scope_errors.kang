// 作用域违规 — 语义层应拒绝
// 覆盖: var重声明参数, 使用未声明变量, 循环后访问循环变量, 函数/变量重名

// ── var 重新声明参数 ─────────────────────────────────────

// ERROR: var 重新声明参数 a
def bad_shadow_param(a:i32) -> i32 {
    var a:i32 = 5;
    return a;
}

// ── 使用未声明变量 ────────────────────────────────────────

// ERROR: 使用未声明的变量 y
def bad_undeclared() -> i32 {
    var x:i32 = 1;
    return x + y;
}

// ── 循环后访问循环变量 ────────────────────────────────────

// ERROR: 循环结束后访问 i
def bad_loop_var() -> i32 {
    for var i:i32 = 0, i < 10, i = i + 1 in {
        puts(str(i));
    }
    return i;
}

// ── 函数名与变量名冲突 ────────────────────────────────────

// ERROR: 变量名与函数名冲突
def same_name() -> i32 {
    return 1;
}

def caller() -> void {
    var same_name:i32 = 2;  // 遮蔽函数名 — 命名空间冲突
    puts(str(same_name));
    return;
}

// ── 内层块遮蔽外层 (合法, 但验证不误报) ────────────────────

// 以下应通过语义检查 (合法遮蔽)
def legal_shadow(x:i32) -> i32 {
    var y:i32 = x;
    {
        var y:i32 = y + 1;  // 合法: 内层遮蔽外层
        return y;
    }
}
