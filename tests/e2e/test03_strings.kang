// test03_strings.kang — 字符串拼接、str() 类型转换、索引

def main() -> i32 {
    // 字符串拼接
    var a:str = "Hello";
    var b:str = "World";
    var c:str = a + " " + b;
    if c == "Hello World" then {
        puts("字符串拼接: OK");
    } else {
        puts("字符串拼接: FAIL");
        return 1;
    }

    // 空字符串拼接
    var empty:str = "";
    var concat_empty:str = empty + "test";
    if concat_empty == "test" then {
        puts("空字符串拼接: OK");
    } else {
        puts("空字符串拼接: FAIL");
        return 1;
    }

    // str(i32)
    var si:str = str(42);
    if si == "42" then {
        puts("str(i32): OK");
    } else {
        puts("str(i32): FAIL");
        return 1;
    }

    // str(i32) 负数
    var sneg:str = str(-10);
    if sneg == "-10" then {
        puts("str(负数): OK");
    } else {
        puts("str(负数): FAIL");
        return 1;
    }

    // 字符串与 i32 拼接 (通过 str() 显式转换)
    var mixed:str = "value=" + str(100);
    if mixed == "value=100" then {
        puts("字符串+i32拼接: OK");
    } else {
        puts("字符串+i32拼接: FAIL");
        return 1;
    }

    // 多段拼接
    var multi:str = "a" + "b" + "c";
    if multi == "abc" then {
        puts("多段拼接: OK");
    } else {
        puts("多段拼接: FAIL");
        return 1;
    }

    // len(str)
    var slen:i32 = len("Hello");
    if slen == 5 then {
        puts("len(str): OK");
    } else {
        var msg:str = "len(str): FAIL, got " + str(slen);
        puts(msg);
        return 1;
    }

    // str(bool)
    var st:str = str(true);
    if st == "true" then {
        puts("str(true): OK");
    } else {
        var msg:str = "str(true): FAIL, got '" + st + "'";
        puts(msg);
        return 1;
    }

    var sf:str = str(false);
    if sf == "false" then {
        puts("str(false): OK");
    } else {
        puts("str(false): FAIL");
        return 1;
    }

    // 字符串索引
    var s:str = "ABCD";
    var ch:str = s[0];
    if ch == "A" then {
        puts("字符串索引 s[0]: OK");
    } else {
        puts("字符串索引 s[0]: FAIL");
        return 1;
    }

    var last:str = s[3];
    if last == "D" then {
        puts("字符串索引 s[3]: OK");
    } else {
        puts("字符串索引 s[3]: FAIL");
        return 1;
    }

    // 字符串拼接中隐式调用 str(bool)
    var bmsg:str = "flag=" + str(true);
    if bmsg == "flag=true" then {
        puts("字符串+bool拼接: OK");
    } else {
        var msg:str = "字符串+bool拼接: FAIL, got '" + bmsg + "'";
        puts(msg);
        return 1;
    }

    puts("字符串测试全部通过");
    return 0;
}
